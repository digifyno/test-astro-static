---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} - AstroStatic`} description={post.data.description}>
  <article class="mx-auto max-w-3xl px-4 py-16">
    <header class="mb-8">
      <a href="/blog" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">&larr; Back to blog</a>
      <h1 class="mt-4 text-4xl font-bold">{post.data.title}</h1>
      <time datetime={post.data.date.toISOString().split('T')[0]} class="mt-2 block text-sm text-gray-500 dark:text-gray-400">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>
    <div class="prose prose-gray dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
